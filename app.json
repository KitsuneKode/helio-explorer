{
  "expo": {
    "name": "Helio",
    "slug": "helio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "helio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kitsunekode.helio"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kitsunekode.helio"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.ico"
    },
    "plugins": [
      "expo-router",
      [
        "expo-quick-actions",
        {
          "androidIcons": {
            "velocity": {
              "foregroundImage": "./assets/images/velocity.png",
              "backgroundColor": "#f8f7f4"
            }
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8f7f4",
          "image": "./assets/images/splash.png",
          "dark": {
            "image": "./assets/images/splash.png",
            "backgroundColor": "#0a0a0a"
          },
          "imageWidth": 220
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8acc4812-0e38-4abb-8f64-6f0699fd8965"
      }
    }
  }
}
